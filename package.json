{
  "name": "seucarro-connect",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "security:secrets": "secretlint \"**/*\"",
    "security:bundle": "node scripts/check-client-secrets.mjs",
    "security:rls": "node --env-file=.env.test supabase/tests/rls.spec.mjs",
    "security:all": "npm run security:secrets && npm run security:bundle"
  },
  "lint-staged": {
    "*": [
      "secretlint"
    ]
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.83.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas-pro": "^2.0.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.462.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^12.1.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.32.0",
    "eslint-config-next": "^16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "secretlint": "^12.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
